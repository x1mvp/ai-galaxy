# =============================================================================
# X1MVP PORTFOLIO API - ENVIRONMENT CONFIGURATION
# =============================================================================

# Application Settings
DEBUG=false
LOG_LEVEL=INFO
LOG_TO_FILE=false

# FastAPI Settings
APP_TITLE=x1mvp Portfolio API
APP_VERSION=3.0.0

# CORS Settings
ALLOWED_ORIGINS=https://x1mvp.github.io,http://localhost:3000,http://localhost:8080

# NLP Settings
NLP_MODEL_NAME=cardiffnlp/twitter-roberta-base-sentiment-latest
NLP_BATCH_SIZE=16
NLP_MAX_LENGTH=512
NLP_DEVICE=auto

# Performance Settings
MAX_REQUEST_SIZE=10000000
REQUEST_TIMEOUT=30

# Redis Settings (for rate limiting)
REDIS_URL=redis://localhost:6379

# Database Settings (if needed)
DATABASE_URL=postgresql://user:password@localhost/dbname

# Security Settings
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Testing
TESTING=false

# Docker/Container Settings
HOST=0.0.0.0
PORT=8000
