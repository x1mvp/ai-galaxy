  "deployment": {
    "infrastructure": {
      "provider": "Google Cloud Platform",
      "region": "us-central1",
      "project": "x1mvp-portfolio",
      "environment": "production"
    },
    "services": {
      "crm": {
        "platform": "Cloud Run",
        "instances": 3,
        "memory": "1Gi",
        "cpu": "1000m",
        "concurrency": 80
      },
      "fraud": {
        "platform": "Cloud Run",
        "instances": 5,
        "memory": "2Gi", 
        "cpu": "2000m",
        "concurrency": 100
      },
      "clinical": {
        "platform": "Cloud Run",
        "instances": 2,
        "memory": "1Gi",
        "cpu": "1000m",
        "concurrency": 50
      },
      "nlp": {
        "platform": "Cloud Run",
        "instances": 4,
        "memory": "2Gi",
        "cpu": "2000m",
        "concurrency": 100
      }
    },
    "databases": {
      "postgresql": {
        "instance": "portfolio-db",
        "tier": "db-custom-4-16384",
        "location": "us-central1",
        "backup": "daily",
        "retention": "30 days"
      },
      "redis": {
        "instance": "portfolio-redis",
        "tier": "standard-1",
        "memory": "4Gi",
        "persistence": "yes"
      }
    }
  },
  "testing": {
    "environments": {
      "integration": {
        "baseUrl": "https://test.x1mvp.dev",
        "database": "test-db",
