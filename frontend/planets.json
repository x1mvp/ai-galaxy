    "performance": {
      "loadTesting": "k6",
      "maxUsers": 1000,
      "duration": "10m",
      "targetLatency": "500ms"
    }
  },
  "maintenance": {
    "windows": {
      "daily": "02:00-03:00 UTC",
      "weekly": "Sunday 04:00-06:00 UTC",
      "monthly": "First Sunday 08:00-12:00 UTC"
    },
    "notifications": {
      "advance": "24 hours",
      "channels": ["email", "slack"],
      "stakeholders": ["dev-team@x1mvp.dev", "ops-team@x1mvp.dev"]
